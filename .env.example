# Copy to .env (which is gitignored) for local runs, or set these in
# Portainer's "Environment variables" field when deploying the stack.
TMDB_API_KEY=your_tmdb_v3_key_here

# Optional — Rotten Tomatoes scores (free key: https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=

# Region for "Trending in cinemas" + streaming availability (GB, US, …)
TMDB_REGION=US

# Optional — Radarr/Sonarr (see README)
RADARR_URL=
RADARR_API_KEY=
SONARR_URL=
SONARR_API_KEY=
